# VeneerPro — Production environment template
# Copy this to .env and fill in your real values.
# Never commit .env to git.

# ── Core ─────────────────────────────────────────────────────────
DEBUG=False
SECRET_KEY=replace-with-a-long-random-string-at-least-50-chars

# ── Server ───────────────────────────────────────────────────────
# Comma-separated list of domains/IPs that can access this server
ALLOWED_HOSTS=yourdomain.com,www.yourdomain.com

# ── Database ─────────────────────────────────────────────────────
DB_ENGINE=postgres
DB_NAME=veneer_pro_db
DB_USER=veneer_user
DB_PASSWORD=replace-with-strong-db-password
DB_HOST=localhost
DB_PORT=5432

# ── Static files (run: python manage.py collectstatic) ───────────
STATIC_ROOT=/var/www/veneer_pro/static/

# ── SSL (enable after confirming HTTPS works) ────────────────────
# SECURE_SSL_REDIRECT=True
# SECURE_HSTS_SECONDS=31536000
# SECURE_HSTS_INCLUDE_SUBDOMAINS=True
